# The initial review build runs without these values and uses fictional local data.
# Add a Supabase free-tier project in the next iteration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Use "live" only after Cloudflare Pages Functions and D1 are configured.
# Any other value keeps the fictional, no-network review mode.
VITE_DATA_MODE=preview
VITE_API_BASE_URL=
