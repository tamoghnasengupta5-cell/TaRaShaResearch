    "vite": "8.1.4",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260711.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
